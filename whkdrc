.shell powershell

# Reload configs
win + shift + r         : komorebic reload-configuration
win + shift + q         : taskkill /f /im whkd.exe; Start-Process whkd -WindowStyle hidden

# Apps (mirrors Hyprland: Super+Return, Super+B, Super+E, Super+R)
win + return            : Start-Process wt
win + b                 : Start-Process firefox
win + e                 : Start-Process explorer
win + r                 : Start-Process "C:\Program Files\yasb\yasbc.exe"

# Close / float / fullscreen (mirrors Super+Shift+C, Super+V, Super+F)
win + shift + c         : komorebic close
win + v                 : komorebic toggle-float
win + f                 : komorebic toggle-maximize

# Layout toggle (mirrors Super+Space togglesplit)
win + space             : komorebic cycle-layout next

# Restart YASB (mirrors Super+Shift+Q restart waybar)
win + shift + q         : Stop-Process -Name yasb -Force; Start-Process "C:\Program Files\yasb\yasb.exe"

# Screenshots (mirrors Super+Print selection, Print fullscreen)
win + print             : Start-Process ms-screenclip:
print                   : Start-Process ms-screenclip:
ctrl + alt + s          : Start-Process ms-screenclip:

# Volume (mirrors XF86 keys)
volume_up               : (New-Object -ComObject WScript.Shell).SendKeys([char]175)
volume_down             : (New-Object -ComObject WScript.Shell).SendKeys([char]174)
volume_mute             : (New-Object -ComObject WScript.Shell).SendKeys([char]173)

# Media (mirrors XF86AudioPlay/Next/Prev)
media_play_pause        : (New-Object -ComObject WScript.Shell).SendKeys([char]179)
media_next_track        : (New-Object -ComObject WScript.Shell).SendKeys([char]176)
media_prev_track        : (New-Object -ComObject WScript.Shell).SendKeys([char]177)

# Focus windows with vim keys (mirrors Super+H/J/K/L)
win + h                 : komorebic focus left
win + j                 : komorebic focus down
win + k                 : komorebic focus up
win + l                 : komorebic focus right

# Move windows with vim keys (mirrors Super+Shift+H/J/K/L)
win + shift + h         : komorebic move left
win + shift + j         : komorebic move down
win + shift + k         : komorebic move up
win + shift + l         : komorebic move right

# Resize with vim keys (mirrors Super+Shift+H/L/K/J resize in Hyprland)
win + alt + h           : komorebic resize-axis horizontal decrease
win + alt + l           : komorebic resize-axis horizontal increase
win + alt + k           : komorebic resize-axis vertical decrease
win + alt + j           : komorebic resize-axis vertical increase

# Cycle focus (bonus — no Hyprland equivalent)
win + shift + oem_4     : komorebic cycle-focus previous
win + shift + oem_6     : komorebic cycle-focus next

# Layouts / monocle (mirrors Super+P, Super+J in Hyprland)
win + p                 : komorebic toggle-monocle
win + shift + f         : komorebic toggle-maximize

# Workspaces 1-9 (mirrors Super+1-9)
win + 1                 : komorebic focus-workspace 0
win + 2                 : komorebic focus-workspace 1
win + 3                 : komorebic focus-workspace 2
win + 4                 : komorebic focus-workspace 3
win + 5                 : komorebic focus-workspace 4
win + 6                 : komorebic focus-workspace 5
win + 7                 : komorebic focus-workspace 6
win + 8                 : komorebic focus-workspace 7
win + 9                 : komorebic focus-workspace 8
win + 0                 : komorebic focus-workspace 9

# Move window to workspace (mirrors Super+Shift+1-9,0)
win + shift + 1         : komorebic move-to-workspace 0
win + shift + 2         : komorebic move-to-workspace 1
win + shift + 3         : komorebic move-to-workspace 2
win + shift + 4         : komorebic move-to-workspace 3
win + shift + 5         : komorebic move-to-workspace 4
win + shift + 6         : komorebic move-to-workspace 5
win + shift + 7         : komorebic move-to-workspace 6
win + shift + 8         : komorebic move-to-workspace 7
win + shift + 9         : komorebic move-to-workspace 8
win + shift + 0         : komorebic move-to-workspace 9
